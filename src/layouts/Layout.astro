        <!-- Logo Header -->
        <div class="h-16 flex items-center px-6 border-b border-sidebar-border">
          <img src="/logo.png" alt="Monty Logo" class="h-8 object-contain" />
        </div>

        <!-- Navigation Links -->
        <nav class="px-4 py-6 space-y-1.5 overflow-y-auto">
