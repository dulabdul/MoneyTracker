                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <span class="text-[10px] font-bold">Budgets</span>
          </a>

          <!-- Transfers Link -->
          <a
            href="/transfers"
            class={`flex flex-col items-center justify-center p-3 rounded-2xl border transition-all ${
              isTransfers
                ? "bg-[#2F7E79]/10 border-[#2F7E79]/30 text-[#2F7E79] dark:text-teal-400"
                : "bg-card hover:bg-muted border-border/80 text-foreground"
            }`}
          >
            <div
              class="h-9 w-9 rounded-xl bg-teal-500/10 flex items-center justify-center text-[#2F7E79] dark:text-teal-400 mb-2"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
              </svg>
            </div>
            <span class="text-[10px] font-bold">Transfers</span>
          </a>

          <!-- Goals Link -->
          <a
            href="/financial-goals"
            class={`flex flex-col items-center justify-center p-3 rounded-2xl border transition-all ${
              isGoals
                ? "bg-[#2F7E79]/10 border-[#2F7E79]/30 text-[#2F7E79] dark:text-teal-400"
                : "bg-card hover:bg-muted border-border/80 text-foreground"
            }`}
          >
            <div
              class="h-9 w-9 rounded-xl bg-teal-500/10 flex items-center justify-center text-[#2F7E79] dark:text-teal-400 mb-2"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="6"></circle>
                <circle cx="12" cy="12" r="2"></circle>
              </svg>
            </div>
            <span class="text-[10px] font-bold">Goals</span>
          </a>

          <!-- Analytics Link -->
          <a
            href="/analytics"
            class={`flex flex-col items-center justify-center p-3 rounded-2xl border transition-all ${
              isAnalytics
                ? "bg-[#2F7E79]/10 border-[#2F7E79]/30 text-[#2F7E79] dark:text-teal-400"
                : "bg-card hover:bg-muted border-border/80 text-foreground"
            }`}
          >
            <div
              class="h-9 w-9 rounded-xl bg-teal-500/10 flex items-center justify-center text-[#2F7E79] dark:text-teal-400 mb-2"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <span class="text-[10px] font-bold">Analytics</span>
          </a>

          <!-- Changelog Link -->
          <a
            href="/changelog"
            class={`flex flex-col items-center justify-center p-3 rounded-2xl border transition-all ${
              isChangelog
                ? "bg-[#2F7E79]/10 border-[#2F7E79]/30 text-[#2F7E79] dark:text-teal-400"
                : "bg-card hover:bg-muted border-border/80 text-foreground"
            }`}
          >
            <div
              class="h-9 w-9 rounded-xl bg-teal-500/10 flex items-center justify-center text-[#2F7E79] dark:text-teal-400 mb-2"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <span class="text-[10px] font-bold">Changelog</span>
          </a>
        </div>

        <!-- User Profile inside drawer -->
        <div
          class="mt-6 pt-6 border-t border-border/60 flex items-center justify-between"
        >
          <div class="flex items-center gap-3">
            <div
              class="h-10 w-10 rounded-full bg-sidebar-accent border border-sidebar-border flex items-center justify-center font-bold text-teal-600 dark:text-teal-400 text-sm shadow-inner shrink-0"
