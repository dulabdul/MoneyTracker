---
import "../styles/global.css";
import ToastContainer from "../components/ui/ToastContainer";

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Authentication — Monty", 
  description = "Login or register to access your Monty personal dashboard." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-[#0f172a] text-slate-200 antialiased min-h-[100dvh] flex flex-col font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
    <div class="fixed inset-0 -z-50 h-full w-full bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:24px_24px] opacity-25"></div>
    <div class="fixed inset-0 -z-50 h-full w-full bg-gradient-to-tr from-[#0f172a] via-[#0f172a] to-emerald-500/5"></div>
    
    <main class="flex-1 flex flex-col items-center justify-center p-4">
      <slot />
    </main>
    
    <ToastContainer client:load />
  </body>
</html>
