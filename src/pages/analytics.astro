---
import Layout from "../layouts/Layout.astro";
import AnalyticsDashboard from "../components/AnalyticsDashboard";
import { fetchAllAnalytics } from "../lib/analytics";
import type { AnalyticsData } from "../lib/analytics";

const { supabase } = Astro.locals;

// ── Parse query params ────────────────────────────────────────────────────────
const url = Astro.url;
const year = parseInt(url.searchParams.get("year") || "2026", 10);
const month = parseInt(url.searchParams.get("month") || "6", 10);
const period = (url.searchParams.get("period") || "month") as "month" | "year" | "date";

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect('/login');
}

// ── Fetch all analytics data (5 RPC calls in parallel) ──────────────────────
const analyticsData: AnalyticsData = await fetchAllAnalytics(supabase, user.id, year, month, period);

// ── Cache: short TTL for fresh data ─────────────────────────────────────────
Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate, proxy-revalidate");
---

<Layout
  title="Monty — Advanced Analytics"
  description="Analisis finansial menyeluruh: cashflow, net worth, budget adherence, dan proyeksi goals."
>
  <AnalyticsDashboard client:load data={analyticsData} year={year} month={month} period={period} />
</Layout>
