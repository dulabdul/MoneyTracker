---
import Layout from "../layouts/Layout.astro";
import GoalManager from "../components/GoalManager";
import { isConfigured } from "../lib/supabase";
import type { FinancialGoal } from "../components/GoalManager";

const { supabase, user } = Astro.locals;
if (!user) {
  return Astro.redirect('/login');
}

let goals: FinancialGoal[] = [];

if (isConfigured && supabase) {
  try {
    const { data, error } = await supabase
      .from("financial_goals")
      .select("*")
      .eq("user_id", user.id)
      .order("target_date", { ascending: true });

    if (!error && data) {
      goals = data.map((g: any) => ({
        id: g.id,
        name: g.name,
        target_amount: Number(g.target_amount),
        current_amount: Number(g.current_amount),
        target_date: g.target_date,
        status: g.status as "active" | "achieved" | "paused",
        notes: g.notes || "",
        created_at: g.created_at,
      }));
    }
  } catch (err) {
    console.error("[financial-goals.astro] Failed to fetch goals:", err);
  }
}

Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate, proxy-revalidate");
---

<Layout
  title="Monty — Financial Goals"
  description="Kelola kantong tabungan dan rencana investasi masa depan Anda secara real-time."
>
  <GoalManager client:load initialGoals={goals} />
</Layout>
