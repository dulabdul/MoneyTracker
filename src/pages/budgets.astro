---
import Layout from "../layouts/Layout.astro";
import BudgetManager from "../components/BudgetManager";
import { isConfigured } from "../lib/supabase";
import type { BudgetRow, Category } from "../components/BudgetManager";

const { supabase, user } = Astro.locals;
if (!user) {
  return Astro.redirect('/login');
}

// Extract month/year filters from URL, default to June 2026 to align with seed transactions
const activeMonth = Number(Astro.url.searchParams.get("month") || 6);
const activeYear = Number(Astro.url.searchParams.get("year") || 2026);

let categories: Category[] = [];
let budgetsRaw: any[] = [];
let spentMap: Record<string, number> = {};

if (isConfigured && supabase) {
  try {
    const sDate = new Date(activeYear, activeMonth - 1, 1);
    const eDate = new Date(activeYear, activeMonth, 0, 23, 59, 59, 999);

    const [budgetRes, catRes, txRes] = await Promise.all([
      supabase.from("budgets").select("id, category_id, limit_amount, month, year").eq("user_id", user.id).eq("month", activeMonth).eq("year", activeYear),
      supabase.from("categories").select("id, name, type").or(`user_id.eq.${user.id},user_id.is.null`),
      supabase.from("transactions").select("category_id, amount").eq("user_id", user.id).eq("type", "EXPENSE").gte("created_at", sDate.toISOString()).lte("created_at", eDate.toISOString())
    ]);

    if (!catRes.error && catRes.data) {
      categories = catRes.data as Category[];
    }
    if (!budgetRes.error && budgetRes.data) {
      budgetsRaw = budgetRes.data;
    }
    if (!txRes.error && txRes.data) {
      txRes.data.forEach((tx: any) => {
        const catId = tx.category_id;
        const amt = Number(tx.amount);
        spentMap[catId] = (spentMap[catId] || 0) + amt;
      });
    }
  } catch (err) {
    console.error("[budgets.astro] Failed to fetch data from Supabase:", err);
  }
}

// Merge table records with live computed transactions spent sum
const budgets: BudgetRow[] = budgetsRaw.map((b) => {
  const cat = categories.find((c) => c.id === b.category_id);
  return {
    id: b.id,
    category_id: b.category_id,
    category_name: cat ? cat.name : "—",
    limit_amount: Number(b.limit_amount),
    total_spent: spentMap[b.category_id] || 0,
    month: b.month,
    year: b.year
  };
});

Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate, proxy-revalidate");
---

<Layout
  title="Monty — Budgets"
  description="Atur dan kendalikan pengeluaran bulanan Anda per kategori secara real-time."
>
  <BudgetManager
    client:load
    initialBudgets={budgets}
    categories={categories}
    activeMonth={activeMonth}
    activeYear={activeYear}
  />
</Layout>
