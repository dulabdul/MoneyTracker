---
import Layout from "../layouts/Layout.astro";
import TransferManager from "../components/TransferManager";
import { supabase, isConfigured } from "../lib/supabase";
import type { TransferRow, Wallet } from "../components/TransferManager";

let transfers: TransferRow[] = [];
let wallets: Wallet[] = [];

if (isConfigured && supabase) {
  try {
    const [transferRes, walletRes] = await Promise.all([
      supabase
        .from("transfers")
        .select(`
          id,
          from_wallet_id,
          to_wallet_id,
          amount,
          admin_fee,
          notes,
          transaction_date,
          created_at,
          from_wallet:wallets!from_wallet_id(name),
          to_wallet:wallets!to_wallet_id(name)
        `)
        .order("transaction_date", { ascending: false }),
      supabase
        .from("wallets")
        .select("id, name, balance")
        .order("name", { ascending: true })
    ]);

    if (!walletRes.error && walletRes.data) {
      wallets = walletRes.data as Wallet[];
    }

    if (!transferRes.error && transferRes.data) {
      transfers = (transferRes.data as any[]).map((tf) => ({
        id: tf.id,
        from_wallet_id: tf.from_wallet_id,
        to_wallet_id: tf.to_wallet_id,
        from_wallet_name: tf.from_wallet?.name ?? "—",
        to_wallet_name: tf.to_wallet?.name ?? "—",
        amount: Number(tf.amount),
        admin_fee: Number(tf.admin_fee || 0),
        notes: tf.notes || "",
        transaction_date: tf.transaction_date,
        created_at: tf.created_at,
      }));
    }
  } catch (err) {
    console.error("[transfers.astro] Failed to fetch data from Supabase:", err);
  }
}

// transfers data is updated live - disable cache
Astro.response.headers.set("Cache-Control", "no-store");
---

<Layout
  title="FinGram — Account Transfers"
  description="Pindahkan saldo antar rekening dan dompet digital Anda secara instan dan aman."
>
  <TransferManager client:load initialTransfers={transfers} wallets={wallets} />
</Layout>
