---
// CustomControls.astro - Interactive custom switches, datepicker, and filters matching reference mockup
---

<div class="w-full bg-card border border-border/80 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all space-y-6">
  <!-- Top row: Selectors, switches and pick date -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <!-- Switches Container -->
    <div class="flex flex-wrap items-center gap-4">
      <!-- Income / Spend sliding switch -->
      <div class="relative flex items-center p-1 bg-zinc-100 dark:bg-zinc-800/85 rounded-full border border-border/50 select-none w-52 h-10">
        <!-- Sliding active indicator block -->
        <div id="switch-income-spend-bg" class="absolute top-1 bottom-1 left-1 w-[100px] bg-primary rounded-full transition-all duration-200 shadow shadow-primary/20"></div>
        <button id="switch-income-btn" type="button" class="relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none">Income</button>
        <button id="switch-spend-btn" type="button" class="relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none">Spend</button>
      </div>

      <!-- Month / Year sliding switch -->
      <div class="relative flex items-center p-1 bg-zinc-100 dark:bg-zinc-800/85 rounded-full border border-border/50 select-none w-48 h-10">
        <div id="switch-month-year-bg" class="absolute top-1 bottom-1 left-1 w-[90px] bg-primary rounded-full transition-all duration-200 shadow shadow-primary/20"></div>
        <button id="switch-month-btn" type="button" class="relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none">Month</button>
        <button id="switch-year-btn" type="button" class="relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none">Year</button>
      </div>
    </div>

    <!-- Datepicker & Dropdown Filters -->
    <div class="flex flex-wrap items-center gap-3 relative z-30">
      <!-- Year Selector -->
      <div class="relative group">
        <button id="year-select-btn" type="button" class="h-10 px-4 rounded-full border border-border bg-background hover:bg-muted text-xs font-bold flex items-center gap-1.5 transition-colors focus:outline-none">
          <span>2026</span>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <!-- Custom Dropdown list -->
        <div id="year-dropdown" class="absolute top-12 left-0 w-32 bg-card border border-border rounded-2xl shadow-xl p-1.5 hidden animate-in fade-in slide-in-from-top-2 duration-150">
          {["2024", "2025", "2026", "2027"].map((yr) => (
            <button type="button" class="w-full text-left px-3 py-2 text-xs font-semibold rounded-xl hover:bg-primary/10 hover:text-primary transition-colors text-foreground">{yr}</button>
          ))}
        </div>
      </div>

      <!-- Month Selector -->
      <div class="relative group">
        <button id="month-select-btn" type="button" class="h-10 px-4 rounded-full border border-border bg-background hover:bg-muted text-xs font-bold flex items-center gap-1.5 transition-colors focus:outline-none">
          <span>Juni</span>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="month-dropdown" class="absolute top-12 left-0 w-36 bg-card border border-border rounded-2xl shadow-xl p-1.5 hidden max-h-48 overflow-y-auto">
          {["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"].map((mth) => (
            <button type="button" class="w-full text-left px-3 py-2 text-xs font-semibold rounded-xl hover:bg-primary/10 hover:text-primary transition-colors text-foreground">{mth}</button>
          ))}
        </div>
      </div>

      <!-- Custom Datepicker Button -->
      <div class="relative">
        <button id="datepicker-btn" type="button" class="h-10 px-4 rounded-full bg-[#2F7E79]/10 text-[#2F7E79] dark:text-teal-400 hover:bg-[#2F7E79]/20 font-bold text-xs flex items-center gap-2 border border-[#2F7E79]/20 shadow-sm transition-colors focus:outline-none">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <span id="datepicker-label">Pick Date</span>
        </button>
        <!-- Calendar Dropdown widget -->
        <div id="calendar-dropdown" class="absolute top-12 right-0 bg-card border border-border rounded-3xl p-4 shadow-2xl w-64 hidden animate-in fade-in duration-200">
          <div class="flex items-center justify-between text-xs font-bold border-b border-border pb-2 mb-2">
            <button class="hover:text-primary">&lt;</button>
            <span>Juni 2026</span>
            <button class="hover:text-primary">&gt;</button>
          </div>
          <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold text-muted-foreground mb-1">
            <span>S</span><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span>
          </div>
          <div class="grid grid-cols-7 gap-1 text-center">
            {Array.from({ length: 30 }, (_, i) => (
              <button type="button" class={`h-6 w-6 rounded-full flex items-center justify-center text-[10px] font-bold transition-all ${
                i + 1 === 11 ? 'bg-primary text-white' : 'hover:bg-primary/10 hover:text-primary text-foreground'
              }`}>
                {i + 1}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom row: Sub-filter chips -->
  <div class="flex items-center gap-2.5 border-t border-border/50 pt-4">
    <button id="chip-all" type="button" class="h-9 px-5 rounded-full bg-primary/15 text-primary border border-primary/20 text-xs font-bold transition-all">All</button>
    <button id="chip-income" type="button" class="h-9 px-5 rounded-full border border-border bg-background hover:bg-muted text-muted-foreground hover:text-foreground text-xs font-bold transition-all">Income</button>
    <button id="chip-spend" type="button" class="h-9 px-5 rounded-full border border-border bg-background hover:bg-muted text-muted-foreground hover:text-foreground text-xs font-bold transition-all">Spend</button>
  </div>
</div>

<script>
  // Client-side interactions for sliding switches and dropdown overlays
  
  // 1. Income / Spend sliding switch
  const switchIncomeBtn = document.getElementById("switch-income-btn");
  const switchSpendBtn = document.getElementById("switch-spend-btn");
  const switchBg = document.getElementById("switch-income-spend-bg");

  switchIncomeBtn?.addEventListener("click", () => {
    if (!switchBg) return;
    switchBg.style.left = "4px";
    switchBg.style.width = "100px";
    switchIncomeBtn.className = "relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none";
    if (switchSpendBtn) switchSpendBtn.className = "relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none";
  });

  switchSpendBtn?.addEventListener("click", () => {
    if (!switchBg || !switchIncomeBtn) return;
    switchBg.style.left = "104px";
    switchBg.style.width = "100px";
    switchSpendBtn.className = "relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none";
    switchIncomeBtn.className = "relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none";
  });

  // 2. Month / Year sliding switch
  const switchMonthBtn = document.getElementById("switch-month-btn");
  const switchYearBtn = document.getElementById("switch-year-btn");
  const switchMYBg = document.getElementById("switch-month-year-bg");

  switchMonthBtn?.addEventListener("click", () => {
    if (!switchMYBg) return;
    switchMYBg.style.left = "4px";
    switchMYBg.style.width = "90px";
    switchMonthBtn.className = "relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none";
    if (switchYearBtn) switchYearBtn.className = "relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none";
  });

  switchYearBtn?.addEventListener("click", () => {
    if (!switchMYBg || !switchMonthBtn) return;
    switchMYBg.style.left = "94px";
    switchMYBg.style.width = "90px";
    switchYearBtn.className = "relative flex-1 text-center text-xs font-bold text-white transition-colors duration-200 z-10 focus:outline-none";
    switchMonthBtn.className = "relative flex-1 text-center text-xs font-semibold text-muted-foreground transition-colors duration-200 z-10 focus:outline-none";
  });

  // 3. Dropdowns toggling helper
  function setupDropdown(btnId: string, dropdownId: string) {
    const btn = document.getElementById(btnId);
    const dropdown = document.getElementById(dropdownId);

    btn?.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle("hidden");
    });

    dropdown?.querySelectorAll("button").forEach((item) => {
      item.addEventListener("click", () => {
        const span = btn?.querySelector("span");
        if (span) span.textContent = item.textContent;
        dropdown.classList.add("hidden");
      });
    });

    // Close on click outside
    document.addEventListener("click", () => {
      dropdown?.classList.add("hidden");
    });
  }

  setupDropdown("year-select-btn", "year-dropdown");
  setupDropdown("month-select-btn", "month-dropdown");
  setupDropdown("datepicker-btn", "calendar-dropdown");

  // 4. Sub-filter chips selection toggle
  const chips = [
    { el: document.getElementById("chip-all"), name: "all" },
    { el: document.getElementById("chip-income"), name: "income" },
    { el: document.getElementById("chip-spend"), name: "spend" }
  ];

  chips.forEach((chip) => {
    chip.el?.addEventListener("click", () => {
      chips.forEach((c) => {
        if (c.el) {
          c.el.className = "h-9 px-5 rounded-full border border-border bg-background hover:bg-muted text-muted-foreground hover:text-foreground text-xs font-bold transition-all";
        }
      });
      if (chip.el) {
        chip.el.className = "h-9 px-5 rounded-full bg-primary/15 text-primary border border-primary/20 text-xs font-bold transition-all";
      }
    });
  });
</script>
