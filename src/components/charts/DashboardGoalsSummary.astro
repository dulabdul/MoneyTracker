---
import { supabase, isConfigured } from "../../lib/supabase";

interface Goal {
  id: string;
  name: string;
  target_amount: number;
  current_amount: number;
  target_date: string;
  status: string;
  notes?: string;
}

let activeGoals: Goal[] = [];
let totalSaved = 0;
let totalTarget = 0;
let globalProgress = 0;

if (isConfigured && supabase) {
  try {
    const { data, error } = await supabase
      .from("financial_goals")
      .select("*")
      .eq("status", "active")
      .order("target_date", { ascending: true });

    if (!error && data) {
      activeGoals = data.map((g: any) => ({
        id: g.id,
        name: g.name,
        target_amount: Number(g.target_amount),
        current_amount: Number(g.current_amount),
        target_date: g.target_date,
        status: g.status,
        notes: g.notes,
      }));

      totalSaved = activeGoals.reduce((sum, g) => sum + g.current_amount, 0);
      totalTarget = activeGoals.reduce((sum, g) => sum + g.target_amount, 0);
      globalProgress = totalTarget > 0 ? Math.min(100, Math.round((totalSaved / totalTarget) * 100)) : 0;
    }
  } catch (err) {
    console.error("[DashboardGoalsSummary.astro] Failed to fetch goals:", err);
  }
}

// Format IDR function
function formatIDR(amount: number): string {
  return new Intl.NumberFormat("id-ID", {
    style: "currency",
    currency: "IDR",
    minimumFractionDigits: 0,
  }).format(amount);
}

// Format Date function
function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "short",
    year: "numeric"
  });
}

const nearestGoals = activeGoals.slice(0, 3);
---

<div class="flex flex-col p-5 bg-card border border-border/80 rounded-3xl h-full shadow-sm hover:shadow-md transition-all select-none">
  <div class="flex items-center justify-between mb-4">
    <h4 class="text-xs font-bold text-[#1B5C58] dark:text-teal-400 uppercase tracking-wider flex items-center gap-1.5">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <circle cx="12" cy="12" r="10" />
        <circle cx="12" cy="12" r="6" />
        <circle cx="12" cy="12" r="2" />
      </svg>
      Financial Goals
    </h4>
    <a href="/financial-goals" class="text-xs font-semibold text-[#2F7E79] dark:text-teal-400 hover:text-[#1B5C58] transition-colors decoration-none">
      Lihat semua →
    </a>
  </div>

  <!-- Global Metrics -->
  <div class="space-y-4 flex-1">
    <div class="bg-muted/20 border border-border/40 rounded-2xl p-4 space-y-3">
      <div>
        <p class="text-[10px] uppercase font-bold text-muted-foreground tracking-wider">Total Tabungan Terkumpul</p>
        <p class="text-xl font-black text-foreground mt-0.5">{formatIDR(totalSaved)}</p>
      </div>

      <div class="space-y-1">
        <div class="flex items-center justify-between text-[10px] font-bold text-muted-foreground">
          <span>Global Progress</span>
          <span class="text-emerald-600 dark:text-emerald-400">{globalProgress}%</span>
        </div>
        <div class="h-2 w-full bg-muted/50 dark:bg-zinc-800 rounded-full overflow-hidden">
          <div 
            class="h-full bg-gradient-to-r from-teal-500 to-emerald-500 rounded-full transition-all duration-500" 
            style={`width: ${globalProgress}%`}
          />
        </div>
        <div class="flex justify-between text-[9px] text-muted-foreground/85 mt-0.5">
          <span>{formatIDR(totalSaved)} terkumpul</span>
          <span>Target: {formatIDR(totalTarget)}</span>
        </div>
      </div>
    </div>

    <!-- Nearest Goals List -->
    <div class="space-y-3">
      <p class="text-[10px] uppercase font-extrabold text-[#1B5C58] dark:text-teal-400 tracking-wider">Target Terdekat</p>
      
      {nearestGoals.length === 0 ? (
        <div class="text-center py-6 border border-dashed border-border/80 rounded-2xl text-xs text-muted-foreground flex flex-col items-center justify-center gap-1.5">
          <svg class="h-6 w-6 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10" />
            <circle cx="12" cy="12" r="6" />
            <circle cx="12" cy="12" r="2" />
          </svg>
          <span>Belum ada target tabungan aktif</span>
        </div>
      ) : (
        <div class="space-y-2.5">
          {nearestGoals.map((goal) => {
            const pct = goal.target_amount > 0 ? Math.min(100, Math.round((goal.current_amount / goal.target_amount) * 100)) : 0;
            return (
              <div class="p-3 bg-muted/10 border border-border/30 rounded-2xl hover:border-border/60 hover:bg-muted/15 transition-all space-y-2">
                <div class="flex justify-between items-start">
                  <div>
                    <h5 class="font-bold text-xs text-foreground line-clamp-1">{goal.name}</h5>
                    <p class="text-[9px] text-muted-foreground mt-0.5">
                      Tenggat: {formatDate(goal.target_date)}
                    </p>
                  </div>
                  <span class="text-[10px] font-extrabold text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 dark:bg-emerald-500/20 px-1.5 py-0.5 rounded-md">
                    {pct}%
                  </span>
                </div>

                <div class="space-y-1">
                  <div class="h-1.5 w-full bg-muted/65 dark:bg-zinc-800 rounded-full overflow-hidden">
                    <div 
                      class="h-full bg-gradient-to-r from-teal-500 to-emerald-500 rounded-full transition-all duration-300"
                      style={`width: ${pct}%`}
                    />
                  </div>
                  <div class="flex justify-between text-[9px] text-muted-foreground/80 font-medium">
                    <span>{formatIDR(goal.current_amount)}</span>
                    <span>{formatIDR(goal.target_amount)}</span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
</div>
